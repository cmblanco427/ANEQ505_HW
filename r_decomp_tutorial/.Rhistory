mutate(forward_name = str_trim(forward_name), # Trim whitespace from forward_name column to avoid matching issues
forward_name = str_to_lower(forward_name), # Lowercase forward_name for case-insensitive matching
reverse_name = str_trim(reverse_name), # Trim whitespace from reverse_name
reverse_name = str_to_lower(reverse_name)) # Lowercase reverse_name for case-insensitive matching
# Join forward barcodes to metadata
