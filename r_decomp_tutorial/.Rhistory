mutate(barcode_clean = remove_primer(barcode, "GTGYCAGCMGCCGCGGTAA"), # Clean the barcode by removing primer and '^'
tag_id = str_trim(tag_id), # Trim whitespace from tag_id for consistency
tag_id = str_to_lower(tag_id)) # Convert tag_id to lowercase for case-insensitive matching
# Read reverse FASTA and create cleaned barcode column
reverse_fasta <- read_fasta("C:/Users/blanc/Desktop/mada_data/Retrying3.23/SmMa16S_reverse_barcodes.fasta")
