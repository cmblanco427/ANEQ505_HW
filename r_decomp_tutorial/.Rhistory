# Step 2: Merge the two data frames by the common column 'sample-id'
# - 'by = "sample-id"' tells R to join on this column
# - 'suffixes = c(".old", ".new")' adds suffixes to columns with the same name in both data frames,
#    so we can distinguish which column came from which data frame after merging
# - 'all.x = TRUE' means keep all rows from metadata1, even if there's no match in metadata2
merged_metadata <- merge(metadata1, metadata2, by = "sample-id")
View(merged_metadata)
View(metadata1)
View(metadata2)
# Step 2: Merge the two data frames by the common column 'sample-id'
