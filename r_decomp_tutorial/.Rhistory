reverse_tag = str_to_lower(reverse_tag)) # Lowercase reverse_name for case-insensitive matching
# Prepare forward FASTA for joining by renaming barcode_clean to barcode_forward
forward_fasta_for_join <- forward_fasta_clean %>%
select(tag_id, `barcode-forward` = barcode_clean) # Select only tag_id and cleaned barcode, renaming barcode_clean to barcode_forward
# Join forward barcodes to metadata
metadata_with_fwd <- metadata %>%
left_join(forward_fasta_for_join, by = c("forward_name" = "tag_id"))
# Join forward barcodes to metadata
metadata_with_fwd <- metadata %>%
left_join(forward_fasta_for_join, by = c("forward_tag" = "tag_id"))
# Prepare reverse FASTA for joining by renaming barcode_clean to barcode_reverse
reverse_fasta_for_join <- reverse_fasta_clean %>%
select(tag_id, `barcode-reverse` = barcode_clean) # Select only tag_id and cleaned barcode, renaming barcode_clean to barcode_reverse
# Join reverse barcodes to metadata_with_fwd
metadata_with_barcodes <- metadata_with_fwd %>%
left_join(reverse_fasta_for_join, by = c("reverse_tag" = "tag_id"))
# Select only the columns needed for output
# sample-id (from Sample_Name), and cleaned forward and reverse barcodes
output_df <- metadata_with_barcodes %>%
select(`sample-id` = `sample-id`, `barcode-forward`, `barcode-reverse`)
