barcode <- str_remove(barcode, paste0(primer_seq, ".*$"))  # Remove the primer sequence and anything after it from the barcode string
barcode <- str_replace_all(barcode, "\\^", "")   # Remove all caret '^' characters from the barcode string
return(barcode)   # Return the cleaned barcode
}
# Function to read FASTA files (headers and sequences)
read_fasta <- function(fasta_path) {
