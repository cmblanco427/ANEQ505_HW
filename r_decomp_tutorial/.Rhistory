# Read metadata and clean join keys
metadata <- read.csv("C:/Users/blanc/Desktop/mada_data/mada_newmeta/16s_metadata_full.csv", stringsAsFactors = FALSE, check.names = FALSE) %>%
mutate(forward_tag = str_trim(forward_tag), # Trim whitespace from forward_name column to avoid matching issues
forward_tag = str_to_lower(forward_tag), # Lowercase forward_name for case-insensitive matching
