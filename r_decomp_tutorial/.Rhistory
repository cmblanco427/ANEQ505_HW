library(dplyr)
library(stringr)
library(tidyr)
library(readr) #writes TSVs
# Function to remove primer sequence and '^' from barcodes
remove_primer <- function(barcode, primer_seq) {
barcode <- str_remove(barcode, paste0(primer_seq, ".*$"))  # Remove the primer sequence and anything after it from the barcode string
barcode <- str_replace_all(barcode, "\\^", "")   # Remove all caret '^' characters from the barcode string
return(barcode)   # Return the cleaned barcode
}
# Function to read FASTA files (headers and sequences)
read_fasta <- function(fasta_path) {
lines <- readLines(fasta_path)   # Read all lines from the FASTA file
headers <- lines[grepl("^>", lines)] # Extract header lines that start with '>'
sequences <- lines[!grepl("^>", lines)] # Extract sequence lines (non-header lines)
tag_ids <- str_remove(headers, "^>") # Remove the leading '>' from headers to get tag IDs
data.frame(tag_id = tag_ids, barcode = sequences, stringsAsFactors = FALSE) # Create a data frame with tag_id and barcode columns
}
# Read forward FASTA and create cleaned barcode column
